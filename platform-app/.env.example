# ─── Database ────────────────────────────────────────────
# Yandex Managed PostgreSQL (pgBouncer). Replace user/password with your credentials.
DATABASE_URL="postgresql://USER:PASSWORD@your-host.mdb.yandexcloud.net:6432/acp?sslmode=verify-full"

# ─── NextAuth ────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# ─── Yandex OAuth ────────────────────────────────────────
YANDEX_CLIENT_ID=""
YANDEX_CLIENT_SECRET=""

# ─── Yandex Object Storage (S3) ─────────────────────────
S3_ENDPOINT="https://storage.yandexcloud.net"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_BUCKET="acp-assets"

# ─── AI Providers ────────────────────────────────────────
REPLICATE_API_TOKEN=""
OPENAI_API_KEY=""
FAL_KEY=""

# ─── Figma import (optional) ─────────────────────────────
AUTH_FIGMA_ID=""
AUTH_FIGMA_SECRET=""
AUTH_FIGMA_REDIRECT_URI="http://localhost:3000/api/connect/figma/callback"
